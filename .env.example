# ==============================================================================
# Trader Environment Variables
# ==============================================================================

# Core environment setting (live, paper, test, backtest)
TRADER_ENV=test

# Application configuration path
CONFIG_PATH=config/live.yaml

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Redis configuration (used by bus/redis_streams)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Interactive Brokers (IBKR) configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Polygon.io API Credentials
POLYGON_API_KEY=your_polygon_api_key_here

# Alpaca API Credentials
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_PAPER=true

# Databento API Credentials
DATABENTO_API_KEY=your_databento_api_key_here

# Benzinga API Credentials
BENZINGA_API_KEY=your_benzinga_api_key_here

# NewsAPI Credentials
NEWSAPI_API_KEY=your_newsapi_api_key_here

# OpenAI/LLM provider settings for agentic capabilities
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o

# ------------------------------------------------------------------------------
# Pi Agent (apps/agent) — per-provider LLM config
# ------------------------------------------------------------------------------
# The runner in apps/agent/ takes a --provider <name> flag and reads the
# matching env vars. The Claude Code / Codex convention. Defaults to
# anthropic when --provider is omitted.
#
# Override the default provider and model by uncommenting / editing:
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o
# GOOGLE_MODEL=gemini-2.0-flash
#
# Point at a different endpoint (local LLM, proxy, custom gateway) by
# setting the *_BASE_URL var. Optional — leave unset to use the vendor default.
# ANTHROPIC_BASE_URL=
# OPENAI_BASE_URL=
# GOOGLE_BASE_URL=
#
# Note: the "google" provider reads GEMINI_API_KEY, not GOOGLE_API_KEY.
# GEMINI_API_KEY=your_gemini_api_key_here
