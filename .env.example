# ==============================================================================
# Trader Environment Variables
# ==============================================================================

# Core environment setting (live, paper, test, backtest)
TRADER_ENV=test

# Application configuration path
CONFIG_PATH=config/live.yaml

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Redis configuration (used by bus/redis_streams)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Interactive Brokers (IBKR) configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Polygon.io API Credentials
POLYGON_API_KEY=your_polygon_api_key_here

# Alpaca API Credentials
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_PAPER=true

# Databento API Credentials
DATABENTO_API_KEY=your_databento_api_key_here

# Benzinga API Credentials
BENZINGA_API_KEY=your_benzinga_api_key_here

# NewsAPI Credentials
NEWSAPI_API_KEY=your_newsapi_api_key_here

# OpenAI/LLM provider settings for agentic capabilities
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o
