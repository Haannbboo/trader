target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   It makes the environment shut up and use the right version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different OS, they may choose to skip it.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be tracked in version control.
#Poetry.lock

# pdm
#   Similar to Poetry and Pipenv, pdm.lock is generally recommended to be tracked in version control.
#pdm.lock
#   pdm build stage
.pdm-plugins/

# PEP 582 spaces
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

