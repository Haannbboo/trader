{
  "name": "agent",
  "version": "0.1.0",
  "private": true,
  "description": "One-shot Pi Agent driver. Reads a prompt, fetches tools from the AgentGateway via the local forwarder, drives an Agent loop, prints the result.",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@sinclair/typebox": "^0.34.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
